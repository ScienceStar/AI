import redis

# 在连接时指定密码
r = redis.Redis(
    host='localhost',
    port=6379,
    password='314159',      # 添加密码
    decode_responses=True
)

pipe = r.pipeline()  # 默认开启事务
pipe.multi()
pipe.set('test:1', 'a')
pipe.set('test:2', 'b')
pipe.incr('test:counter')
result = pipe.execute()
print(result)  # 输出 [True, True, 1] 对应每条命令的结果